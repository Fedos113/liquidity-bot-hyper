# ====================
# Required
# ====================
RPC_URL=https://rpc.hyperliquid.xyz/evm
PRIVATE_KEY=
WALLET_ADDRESS=
POOL_ADDRESS=0x6c9A33E3b592C0d65B3Ba59355d5Be0d38259285
POSITION_MANAGER_ADDRESS=0xeaD19AE861c29bBb2101E834922B2FEee69B9091
HYPE_ADDRESS=0x5555555555555555555555555555555555555555
USDC_ADDRESS=0xb88339cb7199b77e23db6e890353e22632ba630f

# ====================
# RPC Providers — put API keys only (bot builds the URL) except Chainstack
# ====================
HYPE_RPC_API_KEY=    # API key only   → bot builds https://evmrpc-eu.hyperpc.app/<KEY>?apikey=<KEY>
CHAINSTACK_ENDPOINT= # Full HTTPS URL → used as-is (e.g. https://.../evm or .../nanoreth)
ALCHEMY_API_KEY=     # API key only   → bot builds https://hyperliquid-mainnet.g.alchemy.com/v2/<KEY>
DRPC_API_KEY=        # API key only   → bot builds https://lb.drpc.live/hyperliquid/<KEY>

# ====================
# Optional
# ====================
TOKEN_ID=0                          # Auto-discover on first run
DRY_RUN=false                        # Send real transactions
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR

# ====================
# Bot parameters
# ====================
LOWER_BOUND_PCT=0.99                # Position lower bound
UPPER_BOUND_PCT=1.01                # Position upper bound
SLEEP_INTERVAL=3600                 # Main cycle interval
SLIPPAGE_TOLERANCE=0.005            # Max slippage tolerated
FEE_TIER=500                       # Pool fee tier
FEE_COMPOUND_THRESHOLD_USD=5.0      # Compound if fees above
MIN_WALLET_USD=0.2                  # Min wallet to add funds
UNTOUCHABLE_HYPE=0.02               # Native HYPE reserved for gas
PRIORITY_FEE_MULTIPLIER=1.5        # Gas price multiplier for urgent ops
MAX_PRIORITY_FEE_PER_GAS=0.1       # Max priority fee per gas in gwei (EIP-1559)
PRIORITY_FEE_MULTIPLIER_PRIORITY=2.0 # Priority fee multiplier for urgent ops
MAX_TX_FEE_USD_REGULAR=0.05        # Max tx fee in USD for regular operations
MAX_TX_FEE_USD_PRIORITY=1.0        # Max tx fee in USD for priority operations

# ====================
# Secondary cycle
# ====================
SECONDARY_INNER=300                # Price watcher interval
TX_INTER_SLEEP=1                    # Pause between txs

# ====================
# Downward (anti-IL)
# ====================
HYPE_DROP_THRESHOLD=0.98            # Close below threshold
DOWNWARD_COOLDOWN=3600             # Cooldown after trigger
DOWNWARD_INNER_CYCLE_INTERVAL=300  # Inner retry interval

# ====================
# Upward (surge)
# ====================
HYPE_UPPER_THRESHOLD=1.02          # Trigger above threshold
UPWARD_INNER_CYCLE_INTERVAL=180    # Inner retry interval
UPWARD_DELAY=60                    # Delay before main cycle

