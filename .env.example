# Required
RPC_URL=https://mainnet.base.org
PRIVATE_KEY=
WALLET_ADDRESS=
POOL_ADDRESS=0x3FE04A59Ebd38cF06080a6F60a98D124eb59392A
POSITION_MANAGER_ADDRESS=0xe1f8cd9AC4e4A65F54f38a5CdAfCA44f6dD68b53
WETH_ADDRESS=0x4200000000000000000000000000000000000006
USDC_ADDRESS=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
SWAP_ROUTER_ADDRESS=0x698Cb2b6dd822994581fEa6eA4Fc755d1363A92F
GAUGE_ADDRESS=0xA0B61fdB9f1FB9b917Fe38b49427Fd4D87472D28

# Optional
TOKEN_ID=0                          # Set to 0 to auto-create on first run
DRY_RUN=true                        # Set false to send real transactions
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR

# Bot parameters
LOWER_BOUND_PCT=0.99                # -1% from current price
UPPER_BOUND_PCT=1.01                # +1% from current price
SLEEP_INTERVAL=3600                 # 1 hour in seconds
SLIPPAGE_TOLERANCE=0.005            # 0.5%
FEE_TIER=50                         # 0.05% fee tier (Aerodrome Slipstream)
FEE_COMPOUND_THRESHOLD_USD=1.0      # Min fee value to trigger compounding

# Secondary protection cycle
SECONDARY_CYCLE_INTERVAL=600        # 10 minutes in seconds
DROP_THRESHOLD=0.98                  # Close position if price drops >2% below lower bound

# Token decimals (defaults: ETH=18, USDC=6)
NATIVE_DECIMALS=18
USDC_DECIMALS=6
