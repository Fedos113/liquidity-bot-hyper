# Required
RPC_URL=https://hyperevm.rpc.url
PRIVATE_KEY=
WALLET_ADDRESS=
POOL_ADDRESS=0x6c9A33E3b592C0d65B3Ba59355d5Be0d38259285
POSITION_MANAGER_ADDRESS=0xeaD19AE861c29bBb2101E834922B2FEee69B9091
HYPE_ADDRESS=0x5555555555555555555555555555555555555555
USDC_ADDRESS=0xb88339cb7199b77e23db6e890353e22632ba630f

# Optional
TOKEN_ID=0                          # Set to 0 to auto-create on first run
DRY_RUN=true                        # Set false to send real transactions
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR

# Bot parameters
LOWER_BOUND_PCT=0.96                # -4% from current price
UPPER_BOUND_PCT=1.06                # +6% from current price
SLEEP_INTERVAL=3600                 # 1 hour in seconds
SLIPPAGE_TOLERANCE=0.005            # 0.5%
FEE_TIER=3000                       # 0.3% fee tier
FEE_COMPOUND_THRESHOLD_USD=5.0      # Min fee value to trigger compounding

# Token decimals (defaults: HYPE=18, USDC=6)
HYPE_DECIMALS=18
USDC_DECIMALS=6
